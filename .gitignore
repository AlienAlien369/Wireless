# ============================================================
# RSSB Wireless Management System — .gitignore (UPDATED)
# Covers: ASP.NET Core 8, Next.js 14, PostgreSQL, Docker
# ============================================================


# ─── SECRETS & CONFIG (CRITICAL - NEVER COMMIT) ─────────────
backend/appsettings.json
backend/appsettings.*.json
!backend/appsettings.Example.json

frontend/.env
frontend/.env.*
!frontend/.env.example

.env
.env.*

**/*.pfx
**/*.p12
**/*.key
**/*.pem
**/*.cert


# ─── ASP.NET CORE / .NET ────────────────────────────────────
backend/bin/
backend/obj/
*.user
*.suo
*.userosscache
*.sln.docstates

.vs/
_ReSharper*/
*.DotSettings.user

TestResults/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

*.nupkg
*.snupkg
**/publish/

# ❗ DO NOT ignore migrations in production projects
# backend/Migrations/   <-- removed (important for DB sync)


# ─── NEXT.JS / NODE ─────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.cache/
frontend/build/
frontend/dist/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.pnpm-store/
frontend/.npm
frontend/.yarn/


# ─── TYPESCRIPT ─────────────────────────────────────────────
*.tsbuildinfo
frontend/next-env.d.ts


# ─── DOCKER ─────────────────────────────────────────────────
.docker/
docker-compose.override.yml
docker-compose.local.yml

# Optional: ignore local env for docker
.env.docker


# ─── DATABASE ───────────────────────────────────────────────
*.sql.bak
*.dump
pgdata/
postgres-data/


# ─── OS FILES ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ─── IDE & EDITORS ──────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/launch.json

.idea/
*.swp
*.swo
*~

.fleet/
.cursor/


# ─── LOGS ───────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock


# ─── UPLOADS / MEDIA (use Cloudinary instead) ───────────────
frontend/public/uploads/
backend/wwwroot/uploads/


# ─── COVERAGE & TEST OUTPUT ─────────────────────────────────
coverage/
*.coverage
*.coveragexml
frontend/.nyc_output/


# ─── CACHE / TEMP ───────────────────────────────────────────
.cache/
*.bak
*.tmp
*.temp


# ─── OPTIONAL SECURITY ADDITIONS ────────────────────────────
